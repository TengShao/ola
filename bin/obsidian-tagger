#!/usr/bin/env node

const { program } = require('commander');
const Tagger = require('../src/index');

const tagger = new Tagger();

program
  .name('obsidian-tagger')
  .description('自动为 Obsidian 文档添加标签，支持标签管理和同步')
  .version('1.0.0');

program
  .command('/ola', { isDefault: true })
  .description('主入口，询问用户需求')
  .action(async () => {
    await tagger.mainMenu();
  });

program
  .command('/ola-new')
  .description('执行打标签主流程')
  .action(async () => {
    await tagger.newLabels();
  });

program
  .command('/ola-edit')
  .description('修改/删除标签')
  .action(async () => {
    await tagger.editLabels();
  });

program
  .command('/ola-list')
  .description('查看标签库及关联文档')
  .action(async () => {
    await tagger.listLabels();
  });

program
  .command('/ola-config')
  .description('修改配置（知识库路径、目标文件夹、标签位置）')
  .action(async () => {
    await tagger.config();
  });

program
  .command('/ola-reset')
  .description('重置标签数据库，重新配置')
  .action(async () => {
    await tagger.reset();
  });

program.parse();
