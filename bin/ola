#!/usr/bin/env node

/**
 * Ola 统一入口
 * 自动检测运行环境，加载对应适配器
 */

const path = require('path');

/**
 * 检测运行环境
 */
function detectEnvironment() {
  // OpenClaw 环境
  if (process.env.OPENCLAW_SESSION || process.env.OPENCLAW_GATEWAY) {
    return 'openclaw';
  }
  
  // Obsidian 环境（通过全局变量检测）
  if (typeof global !== 'undefined' && global.app?.vault) {
    return 'obsidian';
  }
  
  // 默认 CLI 环境
  return 'cli';
}

/**
 * 主函数
 */
async function main() {
  const env = detectEnvironment();
  const args = process.argv.slice(2);
  
  // 根据环境加载对应入口
  switch (env) {
    case 'openclaw':
      // OpenClaw 环境
      const openclawEntry = require('./ola-openclaw');
      await openclawEntry.run(args);
      break;
      
    case 'obsidian':
      // Obsidian 环境（不应该直接运行此文件）
      console.error('❌ 请在 Obsidian 插件中运行 Ola');
      process.exit(1);
      break;
      
    case 'cli':
    default:
      // CLI 环境
      const cliEntry = require('./ola-cli');
      await cliEntry.run(args);
      break;
  }
}

// 运行
main().catch(error => {
  console.error('❌ 错误:', error.message);
  process.exit(1);
});
