#!/usr/bin/env node

/**
 * Ola CLI - 统一的命令行接口
 * 
 * 设计原则：
 * 1. JSON 输出为默认，方便 Agent 调用
 * 2. 如果是 tty（终端），自动美化输出
 * 3. 如果不带参数且是 tty，进入交互式菜单
 * 
 * 所有环境（Terminal / OpenClaw / Hermes）都用同一套命令
 */

const { program } = require('commander');
const chalk = require('chalk');
const readline = require('readline');
const { OlaAPI } = require('../src/core/api');

// 创建全局 API 实例
const api = new OlaAPI();

// 检测是否为 tty
function isTTY() {
  return process.stdin.isTTY;
}

// JSON 输出 helper
function outputJSON(data) {
  console.log(JSON.stringify(data));
}

// 美化输出（tty 模式）
function output(data, options = {}) {
  if (program.opts().json || (!isTTY() && !options.forceColor)) {
    outputJSON(data);
  } else {
    // 格式化输出
    if (Array.isArray(data)) {
      data.forEach(item => console.log(item));
    } else if (typeof data === 'object') {
      console.log(JSON.stringify(data, null, 2));
    } else {
      console.log(data);
    }
  }
}

// 确保已初始化
function ensureInit() {
  const cfg = api.getConfig();
  if (!cfg) {
    const msg = { error: 'Not configured', code: 'NOT_CONFIGURED' };
    program.opts().json ? outputJSON(msg) : console.error(chalk.red('❌ 未配置'));
    process.exit(1);
  }
  return cfg;
}

// 初始化
api.init();

program
  .name('ola')
  .description('Ola - AI-powered tagging system for Obsidian notes')
  .version('0.1.0')
  .option('--json', '输出 JSON 格式（默认）')
  .option('--no-json', '禁用 JSON 格式，输出美化文本');

// ==================== 核心命令 ====================

// vaults - 查找 vault
program
  .command('vaults')
  .description('查找所有 Obsidian vault')
  .action(async () => {
    const vaults = api.findVaults();
    output({ vaults });
  });

// config - 配置管理
program
  .command('config')
  .description('查看或修改配置')
  .option('--vault <path>', '设置 vault 路径')
  .option('--folder <path>', '设置目标文件夹')
  .option('--position <position>', '设置标签位置 (head/tail)')
  .action(async (options) => {
    const cfg = api.getConfig();
    
    // 如果没有任何选项，显示当前配置
    if (!options.vault && !options.folder && !options.position) {
      output({ config: cfg });
      return;
    }

    // 修改配置
    const newCfg = {
      ...cfg,
      vaultPath: options.vault || cfg?.vaultPath,
      targetFolder: options.folder || cfg?.targetFolder || '/',
      labelPosition: options.position || cfg?.labelPosition || 'tail',
      initialized: true
    };
    api.saveConfig(newCfg);
    output({ success: true, config: newCfg });
  });

// scan - 扫描文档
program
  .command('scan')
  .description('扫描文件夹中的文档')
  .option('--folder <path>', '文件夹路径（相对于 vault）', '/')
  .option('--untagged', '仅返回未打标文档')
  .action(async (options) => {
    const cfg = ensureInit();
    const docs = await api.scan(options.folder);
    
    if (options.untagged) {
      const untagged = api.getUntagged(docs);
      output({ 
        folder: options.folder, 
        total: docs.length, 
        untagged: untagged.length, 
        docs: untagged 
      });
    } else {
      output({ folder: options.folder, total: docs.length, docs });
    }
  });

// suggest - 生成标签建议
program
  .command('suggest')
  .description('为文档生成标签建议（需要 AI 配置）')
  .requiredOption('--path <path>', '文档路径（相对于 vault）')
  .action(async (options) => {
    ensureInit();
    
    const result = await api.generateTags(options.path);
    output(result);
  });

// tag - 应用标签
program
  .command('tag')
  .description('应用标签到文档')
  .requiredOption('--path <path>', '文档路径（相对于 vault）')
  .requiredOption('--tags <tags>', '标签（逗号分隔）')
  .option('--position <position>', '位置', 'tail')
  .action(async (options) => {
    ensureInit();
    
    const tags = options.tags.split(',').map(t => t.trim()).map(t => t.startsWith('#') ? t : '#' + t);
    const result = api.applyTags(options.path, tags, options.position);
    output(result);
  });

// list - 列出标签
program
  .command('list')
  .description('列出所有标签')
  .action(async () => {
    const tags = api.listTags();
    output({ tags });
  });

// rename - 重命名标签
program
  .command('rename')
  .description('重命名标签')
  .requiredOption('--old <tag>', '旧标签')
  .requiredOption('--new <tag>', '新标签')
  .action(async (options) => {
    ensureInit();
    
    const oldTag = options.old.startsWith('#') ? options.old : '#' + options.old;
    const newTag = options.new.startsWith('#') ? options.new : '#' + options.new;
    
    const result = api.renameTag(oldTag, newTag);
    output(result);
  });

// delete - 删除标签
program
  .command('delete')
  .description('删除标签')
  .requiredOption('--tag <tag>', '要删除的标签')
  .action(async (options) => {
    ensureInit();
    
    const tag = options.tag.startsWith('#') ? options.tag : '#' + options.tag;
    const result = api.deleteTag(tag);
    output(result);
  });

// ==================== 交互模式 ====================

// 如果没有参数且是 tty，进入交互模式
program.action(async () => {
  const args = process.argv.slice(2);
  
  if (args.length === 0 && isTTY()) {
    // 进入交互式菜单
    const Tagger = require('../src/index');
    const tagger = new Tagger();
    await tagger.mainMenu();
  } else if (args.length === 0) {
    // 非 tty 模式，显示帮助
    program.help();
  } else {
    // 有参数但无法识别
    console.error(chalk.red(`❌ 未知命令: ${args.join(' ')}`));
    program.help();
  }
});

program.parse();
