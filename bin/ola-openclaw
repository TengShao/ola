#!/usr/bin/env node

/**
 * OpenClaw 入口（完整交互版）
 * 按 PRD 规范实现多轮对话
 */

const OpenClawHandler = require('../src/openclaw/handler');

// 检测环境
const isOpenClaw = !!process.env.OPENCLAW_SESSION || 
                   !!process.env.OPENCLAW_GATEWAY;

if (!isOpenClaw) {
  console.error('❌ 此入口仅用于 OpenClaw 环境');
  process.exit(1);
}

// 获取会话 ID 和命令
const sessionId = process.env.OPENCLAW_SESSION || 'default';
const args = process.argv.slice(2);
const command = args[0] || '/ola';
const userInput = args[1] || null; // 用户回复内容

const handler = new OpenClawHandler();

async function main() {
  try {
    switch (command) {
      case '/ola':
      case '/ola new':
        const result = await handler.handleNewLabels(sessionId, userInput);
        console.log(result.message);
        break;
        
      case '/ola list':
        const listResult = await handler.handleListTags();
        console.log(listResult.message);
        break;
        
      case '/ola config':
        console.log('⚙️ 配置请在 CLI 环境下运行: ola /ola-dev:ai-config');
        break;
        
      default:
        console.log(`❓ 未知命令: ${command}`);
        console.log('可用: /ola, /ola new, /ola list');
    }
  } catch (error) {
    console.error('❌ 错误:', error.message);
    process.exit(1);
  }
}

main();
